rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /ride_sessions/{sessionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.participant_ids.hasAny([request.auth.uid]);
      allow create: if isSignedIn() && incoming().leader_id == request.auth.uid;
      allow update: if isSignedIn() && (
        existing().leader_id == request.auth.uid || 
        (incoming().diff(existing()).affectedKeys().hasOnly(['participant_ids']) && 
         incoming().participant_ids.hasAll(existing().participant_ids))
      );

      match /members/{memberId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
